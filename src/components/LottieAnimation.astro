---
export interface Props {
  src: string;
  alt?: string;
  class?: string;
}

const { src, alt = 'Animation', class: className = '' } = Astro.props;

// Convert the path alias to a relative path
const relativePath = src.replace('~/', '../');

// Import the JSON animation data at build time
const animationModule = await import(/* @vite-ignore */ relativePath);
const animationData = animationModule.default || animationModule;

// Convert to JSON string to embed in lottie-player
const animationJson = JSON.stringify(animationData);
---

<!-- Use lottie-player web component -->
<script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>

<lottie-player
  class={className}
  autoplay
  loop
  mode="normal"
  style="width: 100%; height: 500px;"
  aria-label={alt}
>
  <script is:inline type="application/json" set:html={animationJson}></script>
</lottie-player>

<style>
  lottie-player {
    max-width: 100%;
    margin: 0 auto;
  }
</style>
