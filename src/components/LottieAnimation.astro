---
export interface Props {
  src: string;
  alt?: string;
  class?: string;
}

const { src, alt = 'Animation', class: className = '' } = Astro.props;

// Just use the filename from public folder
const fileName = src.split('/').pop();
---

<!-- Use lottie-player web component with src attribute -->
<script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>

<lottie-player
  src={`/${fileName}`}
  background="transparent"
  speed="1"
  class={className}
  loop
  autoplay
  style="width: 100%; height: 350px;"
></lottie-player>

<style>
  lottie-player {
    max-width: 100%;
    margin: -2rem auto 0;
    display: block;
  }
</style>
