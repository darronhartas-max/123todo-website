---
export interface Props {
  src: string;
  alt?: string;
  class?: string;
}

const { src, alt = 'Animation', class: className = '' } = Astro.props;
const animationId = `lottie-${Math.random().toString(36).substr(2, 9)}`;

// Import the JSON file at build time
const modules = import.meta.glob('~/assets/**/*.json');
const animationData = await modules[src]?.();
---

<div id={animationId} class={`lottie-animation ${className}`} role="img" aria-label={alt} data-animation={JSON.stringify(animationData?.default || animationData)}></div>

<script>
  import lottie from 'lottie-web';

  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll('.lottie-animation[data-animation]');

    containers.forEach((container) => {
      try {
        const animationDataStr = container.getAttribute('data-animation');
        if (animationDataStr) {
          const animationData = JSON.parse(animationDataStr);

          lottie.loadAnimation({
            container: container as HTMLElement,
            renderer: 'svg',
            loop: true,
            autoplay: true,
            animationData: animationData
          });
        }
      } catch (error) {
        console.error('Failed to load Lottie animation:', error);
      }
    });
  });
</script>

<style>
  .lottie-animation {
    width: 100%;
    height: auto;
    min-height: 300px;
  }
</style>
