---
// Cookie/Terms Popup Announcement
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 bg-blue-900 dark:bg-slate-900 text-white px-4 py-4 shadow-lg z-50 hidden"
>
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex-1 text-sm md:text-base">
      <p>
        <strong>Privacy Notice:</strong> 123 ToDo uses no cookies and collects no personal data. By using this website, you
        agree to our
        <a href="/terms" class="underline hover:text-blue-200">Terms of Service</a> and
        <a href="/privacy" class="underline hover:text-blue-200">Privacy Policy</a>.
      </p>
    </div>
    <button
      id="accept-cookies"
      class="bg-white text-blue-900 hover:bg-blue-50 px-6 py-2 rounded-md font-semibold whitespace-nowrap transition"
    >
      Got It
    </button>
  </div>
</div>

<script>
  // Cookie banner logic
  const banner = document.getElementById('cookie-banner');
  const acceptButton = document.getElementById('accept-cookies');

  // Check if user has already acknowledged
  const hasAcknowledged = localStorage.getItem('cookie-banner-acknowledged');

  if (!hasAcknowledged && banner) {
    banner.classList.remove('hidden');
  }

  // Handle acceptance
  if (acceptButton) {
    acceptButton.addEventListener('click', () => {
      localStorage.setItem('cookie-banner-acknowledged', 'true');
      if (banner) {
        banner.classList.add('hidden');
      }
    });
  }
</script>
