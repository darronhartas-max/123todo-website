---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'About Us',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero>
    <Fragment slot="title">
      About <span class="text-accent dark:text-white">123 ToDo</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="text-lg">
        A privacy-first task manager built for people who value simplicity and control over their data.
      </span>
    </Fragment>
  </Hero>

  <!-- Our Story -->
  <Content
    tagline="Our Story"
    title="Why we built 123 ToDo"
    items={[]}
    image={{
      src: '~/assets/images/default.png',
      alt: 'Our story - Why we built 123 ToDo'
    }}
  >
    <Fragment slot="content">
      <p class="text-lg mb-6">
        In a world where every app wants your email, tracks your behavior, and stores your data in the cloud,
        we asked a simple question: <span class="font-semibold">Why can't task management be simpler?</span>
      </p>

      <p class="text-lg mb-6">
        123 ToDo was born from frustration with overcomplicated productivity tools that promise the world
        but deliver bloat, subscription fees, and privacy concerns. We believe task management should be:
      </p>

      <ul class="text-lg mb-6 space-y-2 list-disc list-inside">
        <li><span class="font-semibold">Fast</span> - No waiting for cloud sync or page loads</li>
        <li><span class="font-semibold">Private</span> - Your tasks stay on your device, period</li>
        <li><span class="font-semibold">Simple</span> - Powerful features without overwhelming complexity</li>
        <li><span class="font-semibold">Free</span> - No subscriptions, no paywalls, no premium tiers</li>
      </ul>

      <p class="text-lg mb-6">
        So we built it. A Progressive Web App that works offline, respects your privacy, and helps you
        get things done without getting in your way.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Our Mission -->
  <Content
    isReversed
    tagline="Our Mission"
    title="Building tools that respect users"
    items={[]}
    image={{
      src: '~/assets/images/default.png',
      alt: 'Our mission - Building tools that respect users'
    }}
  >
    <Fragment slot="content">
      <p class="text-lg mb-6">
        Our mission is to create productivity tools that put users first - not advertisers, not investors,
        not data brokers. Just you and your tasks.
      </p>

      <h3 class="text-xl font-bold mb-3">What we believe:</h3>

      <p class="text-lg mb-4">
        <span class="font-semibold">Privacy is a right, not a feature.</span><br/>
        Your tasks, goals, and daily activities reveal intimate details about your life.
        We believe this information belongs to you alone.
      </p>

      <p class="text-lg mb-4">
        <span class="font-semibold">Simple beats complex.</span><br/>
        The best tool is one you'll actually use. We prioritize clarity and speed over
        endless features most people never touch.
      </p>

      <p class="text-lg mb-4">
        <span class="font-semibold">Local-first is better.</span><br/>
        Your device is more reliable and faster than any cloud server. By storing data locally,
        123 ToDo works anywhere, anytime - no internet required.
      </p>

      <p class="text-lg mb-4">
        <span class="font-semibold">Free means free.</span><br/>
        No "freemium" tricks, no artificial limits. If we built it, you can use it - fully and forever.
      </p>
    </Fragment>
  </Content>

  <!-- The Team -->
  <Content
    tagline="The Team"
    title="Who we are"
    items={[]}
    image={{
      src: '~/assets/images/default.png',
      alt: 'The 123 ToDo team'
    }}
  >
    <Fragment slot="content">
      <p class="text-lg mb-6">
        123 ToDo is created and maintained by independent developers who care about building
        ethical software. We're not a venture-backed startup racing to monetize users.
        We're people who use this app daily and want to share it with others.
      </p>

      <p class="text-lg mb-6">
        This project is supported entirely by its users. If you find value in 123 ToDo,
        the best way to support us is to:
      </p>

      <ul class="text-lg mb-6 space-y-2 list-disc list-inside">
        <li>Share it with friends and colleagues who value privacy</li>
        <li>Provide feedback on features and improvements</li>
        <li>Report bugs and help us make it better</li>
        <li>Spread the word about privacy-first software</li>
      </ul>

      <p class="text-lg">
        Thank you for being part of the 123 ToDo community.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Technology -->
  <Content
    isReversed
    tagline="Technology"
    title="Built with modern web standards"
    items={[
      {
        title: 'Progressive Web App (PWA)',
        description: 'Install on any device and use like a native app. Works offline with full functionality.',
      },
      {
        title: 'React 19',
        description: 'Built with the latest React for smooth, responsive performance and excellent user experience.',
      },
      {
        title: 'Browser localStorage',
        description: 'All data stored locally in your browser using standard Web Storage API. No servers, no databases.',
      },
      {
        title: 'Open Standards',
        description: 'Built with web standards that work everywhere. Export your data anytime as standard JSON.',
      },
    ]}
    image={{
      src: '~/assets/images/default.png',
      alt: 'Modern web technology stack'
    }}
  >
    <Fragment slot="content">
      <p class="text-lg mb-6">
        123 ToDo leverages modern web technologies to deliver a fast, reliable experience
        without compromising on privacy or requiring complex infrastructure.
      </p>

      <p class="text-lg">
        By using browser localStorage and service workers, we can offer offline functionality
        and instant load times while keeping your data entirely under your control.
      </p>
    </Fragment>
  </Content>

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Using 123 ToDo',
        href: 'https://app.123todo.com',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to take control of your tasks?
    </Fragment>

    <Fragment slot="subtitle">
      Join users who've chosen privacy and simplicity. No signup required.
    </Fragment>
  </CallToAction>
</Layout>
