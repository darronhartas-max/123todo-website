---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'User Guide',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    image={{
      src: '~/assets/images/frustrated.jpg',
      alt: 'Frustrated with task management - let us help',
    }}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white">User Guide</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="text-lg"> Everything you need to know to master 123 ToDo </span>
    </Fragment>
  </Hero>

  <!-- Getting Started -->
  <Steps
    title="Getting Started with 123 ToDo"
    subtitle="Get up and running in under 60 seconds"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Open the App</span>',
        description:
          'Visit <a href="https://app.123todo.com" class="text-blue-600 hover:underline">app.123todo.com</a> in any modern web browser. No download or installation required to start.',
        icon: 'tabler:world',
      },
      {
        title: 'Step 2: <span class="font-medium">Add Your First Task</span>',
        description:
          'Click the "Add Task" button at the top of any priority section. Type your task (up to 200 characters) and select a priority level.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Step 3: <span class="font-medium">Organize and Complete</span>',
        description:
          "Drag tasks to reorder them within priorities. Click the checkbox to mark tasks complete. That's it - you're managing tasks!",
        icon: 'tabler:check',
      },
      {
        title: 'Step 4: <span class="font-medium">Install as PWA (Recommended)</span>',
        description:
          'For the best mobile experience, install 123 ToDo as a Progressive Web App. This ensures **Persistent Storage** so your tasks are never cleared by the OS.',
        icon: 'tabler:download',
      },
      {
        title: 'Step 5: <span class="font-medium">Enable Google Drive Sync</span>',
        description:
          'Want to sync across your phone and computer? Click the "Google Drive Sync" button in the footer to seamlessly sync your tasks across devices using AES-256 encrypted storage.',
        icon: 'tabler:cloud-upload',
      },
    ]}
  />

  <!-- Features Deep Dive -->
  <section class="px-4 py-16 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Features Deep Dive</h2>
      <p class="text-xl text-gray-600 dark:text-gray-400">Master every feature of 123 ToDo</p>
    </div>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h3>🎯 Priority System</h3>
      <p>123 ToDo uses a 4-level priority system to help you focus on what matters most:</p>
      <ul>
        <li>
          <strong class="text-red-600">Must Do (Priority 1)</strong> - Critical tasks that must be completed today. These
          appear in red.
        </li>
        <li>
          <strong class="text-orange-600">Should Do (Priority 2)</strong> - Important tasks that should be done soon. These
          appear in orange.
        </li>
        <li>
          <strong class="text-gray-600">Could Do (Priority 3)</strong> - Nice-to-have tasks with no urgent deadline. These
          appear in gray.
        </li>
        <li>
          <strong class="text-purple-600">On Hold (Priority 4)</strong> - Tasks that are paused or waiting on something else.
          These appear in purple.
        </li>
      </ul>

      <h3>✏️ Adding and Editing Tasks</h3>
      <p><strong>To add a new task:</strong></p>
      <ol>
        <li>Click the "Add Task" button in any priority section</li>
        <li>Type your task in the modal that appears (200 character limit)</li>
        <li>Select the priority level using the colored buttons</li>
        <li>Click "Add Task" to save</li>
      </ol>

      <p><strong>To edit an existing task:</strong></p>
      <ol>
        <li>Click the pencil icon next to any task</li>
        <li>Modify the text or change the priority</li>
        <li>Click "Update Task" to save changes</li>
      </ol>

      <h3>✅ Completing Tasks</h3>
      <p>
        Click the checkbox next to any task to mark it complete. Completed tasks move to the Archive section at the
        bottom of the page. You can restore archived tasks anytime by clicking the restore icon.
      </p>

      <h3>↕️ Reordering & Moving Tasks</h3>
      <p>Tasks can be sorted and moved using intuitive drag and drop mechanics:</p>
      <ul>
        <li>
          <strong>Sort within a list</strong>: Click and hold any task, then drag it up or down in the same section to
          reorder it.
        </li>
        <li>
          <strong>Move across priorities</strong>: Drag a task to a different priority section. Dropping it on another
          task will assign it to that priority and position it there.
        </li>
        <li>
          <strong>Drop at the very top</strong>: Drag a task directly onto the section header or empty area of a
          priority list to place it at the absolute top (a dashed border will highlight the active drop zone).
        </li>
      </ul>

      <h3>🗑️ Deleting Tasks</h3>
      <p>
        To permanently delete a task, click the trash icon. You'll see a confirmation prompt.
        <strong>Deleted tasks cannot be recovered.</strong>
      </p>

      <h3>📦 Archive System</h3>
      <p>
        Completed tasks are automatically moved to the Archive section at the bottom of the page. The archive shows:
      </p>
      <ul>
        <li>All completed tasks with their original priority colors</li>
        <li>Completion timestamps</li>
        <li>Options to restore (move back to active) or permanently delete</li>
      </ul>

      <h3>🏆 Achievement Milestones</h3>
      <p>
        Stay motivated with daily achievement celebrations! 123 ToDo tracks how many tasks you complete each day and
        celebrates when you hit milestones:
      </p>
      <ul>
        <li><strong>5 tasks</strong> - Bronze milestone 🥉</li>
        <li><strong>10 tasks</strong> - Silver milestone 🥈</li>
        <li><strong>15 tasks</strong> - Gold milestone 🥇</li>
      </ul>
      <p>Milestones reset daily at midnight, giving you fresh motivation every day.</p>

      <h3>📦 Data Import & Migration</h3>
      <p><strong>Migrating from Todoist:</strong></p>
      <ol>
        <li>Click the "Import" button in the footer</li>
        <li>Select "Todoist Export" from the options</li>
        <li>Upload your Todoist CSV files to see your projects converted into 123 ToDo categories</li>
      </ol>

      <p><strong>Importing 123 ToDo Backups:</strong></p>
      <ol>
        <li>Click the "Import" button in the footer</li>
        <li>Select "123 ToDo Backup"</li>
        <li>Choose your previously exported JSON file</li>
      </ol>

      <p>
        <strong>⚠️ Important:</strong> Importing data will merge or replace your current tasks depending on the source. Export
        your current data first if you want to keep a secondary copy!
      </p>

      <h3>☁️ Cross-Device Google Drive Sync</h3>
      <p>
        123 ToDo features a powerful, free synchronization system that lets you access your tasks across all your
        devices (phones, tablets, and computers).
      </p>
      <ul>
        <li>
          <strong>Zero-Knowledge Encryption:</strong> Your data is encrypted with military-grade AES-256-GCM using your personal
          passphrase <em>before</em> it leaves your device. Not even Google can read your tasks.
        </li>
        <li>
          <strong>Invisible Syncing:</strong> Once signed in, the app automatically pulls updates when you open it, and silently
          pushes changes in the background as you work.
        </li>
        <li>
          <strong>Silent Authentication:</strong> Sign in once, and the app will keep you authenticated across sessions seamlessly
          without annoying popups.
        </li>
        <li>
          <strong>Visual Status:</strong> The footer button glows green when active and red when offline, keeping you informed
          without distraction.
        </li>
      </ul>

      <h3>🛡️ Shadow Backups (Automatic)</h3>
      <p>
        123 ToDo includes a built-in <strong>Shadow Backup</strong> system for extra peace of mind. Every 24 hours, the app
        automatically saves a "hidden" snapshot of your tasks internally. If your main task list is ever accidentally cleared,
        this secondary restore point ensures you never lose more than a day's work.
      </p>

      <h3>📱 PWA Installation</h3>
      <p><strong>On Desktop (Chrome, Edge, Brave):</strong></p>
      <ol>
        <li>Visit app.123todo.com</li>
        <li>Click the install icon in the address bar (computer with down arrow)</li>
        <li>Click "Install" in the popup</li>
        <li>The app will open in its own window</li>
      </ol>

      <p><strong>On iPhone/iPad (Safari):</strong></p>
      <ol>
        <li>Visit app.123todo.com in Safari</li>
        <li>Tap the Share button (square with up arrow)</li>
        <li>Scroll down and tap "Add to Home Screen"</li>
        <li>Tap "Add" to confirm</li>
      </ol>

      <p><strong>On Android (Chrome):</strong></p>
      <ol>
        <li>Visit app.123todo.com in Chrome</li>
        <li>Tap the three-dot menu</li>
        <li>Tap "Add to Home screen"</li>
        <li>Tap "Add" to confirm</li>
      </ol>

      <h3>💾 Data Backup Reminders</h3>
      <p>
        123 ToDo will remind you weekly to backup your data. Since all tasks are stored locally in your browser, regular
        backups are essential to prevent data loss.
      </p>

      <h3>🎨 Theme Options</h3>
      <p>
        123 ToDo automatically adapts to your system's light or dark mode preference. If you change your system theme,
        the app will update automatically.
      </p>

      <h3>⌨️ Keyboard Shortcuts</h3>
      <p>
        Accelerate your workflow with these quick keyboard shortcuts (automatically disabled when typing inside input
        fields):
      </p>
      <ul>
        <li>
          <strong><code>a</code></strong> or <strong><code>q</code></strong>: Toggle open/close the "Add Task" panel.
        </li>
        <li><strong><code>/</code></strong>: Toggle and focus the search bar instantly.</li>
        <li><strong><code>s</code></strong>: Open the Settings modal.</li>
        <li><strong><code>Esc</code></strong>: Close any open modal, clear active selections, or collapse panels.</li>
        <li><strong><code>Enter</code></strong>: Save/submit your task while typing in the description textarea.</li>
        <li>
          <strong><code>Shift + Enter</code></strong>: Insert a new line break inside a task's description without
          submitting it.
        </li>
      </ul>
    </div>
  </section>

  <!-- Tips and Tricks -->
  <Features
    id="tips"
    tagline="Tips & Tricks"
    title="Pro tips for maximum productivity"
    subtitle="Get more done with these expert techniques"
    items={[
      {
        title: 'Start Each Day with Must Do',
        description: 'Limit your Must Do list to 3-5 critical tasks. This keeps you focused and prevents overwhelm.',
        icon: 'tabler:target',
      },
      {
        title: 'Use On Hold for Waiting Tasks',
        description: 'Move tasks to On Hold when waiting for others or external factors. Keeps active lists clean.',
        icon: 'tabler:clock-pause',
      },
      {
        title: 'Weekly Reviews',
        description: "Every Sunday, review Could Do tasks. Promote important ones or delete tasks you'll never do.",
        icon: 'tabler:calendar-week',
      },
      {
        title: 'Archive Review',
        description:
          'Periodically review your archive to see progress. Permanently delete old completed tasks to declutter.',
        icon: 'tabler:archive',
      },
      {
        title: 'Regular Backups',
        description: 'Export your data weekly. Set a reminder or do it every Friday. Store backups in cloud storage.',
        icon: 'tabler:database-export',
      },
      {
        title: 'Break Down Big Tasks',
        description:
          'Large projects? Break them into smaller, actionable tasks. "Launch website" becomes 5 specific tasks.',
        icon: 'tabler:list-details',
      },
    ]}
  />

  <!-- FAQ Section -->
  <FAQs
    title="Frequently Asked Questions"
    subtitle="Common questions about using 123 ToDo"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Where is my data stored?',
        description:
          "All your tasks are stored locally in your browser's localStorage. Nothing is sent to our servers. Your data stays on your device.",
      },
      {
        title: 'My devices are signed in but not syncing. What do I do?',
        description:
          'Because of how zero-knowledge encryption works, if one device encrypts data with a new key and another device gets out of sync with the session, it may appear stuck. To fix this, simply tap the sync button on both devices to **Sign Out**, and then sign back in on both devices using the exact same Google account and passphrase. This forces a fresh connection and will resume syncing immediately.',
      },
      {
        title: 'Can I sync between devices?',
        description:
          'YES! We offer a powerful **Google Drive Sync** feature. It connects directly to your personal Google Drive to sync your tasks seamlessly across all your devices. Best of all, it features AES-256-GCM zero-knowledge encryption, meaning your tasks are fully encrypted before they ever leave your device.',
      },
      {
        title: 'Is my data safe on mobile?',
        description:
          'Yes! We use the **Persistent Storage API** on mobile devices. When you install the app as a PWA, we request that the OS never clears your data, making it as robust as a native app.',
      },
      {
        title: 'What happens if I clear my browser data?',
        description:
          'Clearing browser data will delete all your tasks permanently. This is why regular exports are crucial. We cannot recover lost data.',
      },
      {
        title: 'Can I use 123 ToDo offline?',
        description:
          'Yes! Once you visit the site, it works completely offline. Install it as a PWA for the best offline experience.',
      },
      {
        title: 'How many tasks can I create?',
        description:
          "There's no hard limit, but browsers typically limit localStorage to 5-10MB. In practice, this allows thousands of tasks.",
      },
      {
        title: "Can I change a task's priority after creating it?",
        description:
          'Yes! Click the edit icon (pencil) next to any task, then select a new priority level using the colored buttons.',
      },
      {
        title: 'Is there a mobile app?',
        description:
          '123 ToDo IS a mobile app when installed as a PWA! It works offline, appears on your home screen, and functions like a native app.',
      },
      {
        title: 'Do you track how I use the app?',
        description:
          "No. We don't use analytics, cookies, or any tracking. We have no idea how you use 123 ToDo, and we like it that way.",
      },
      {
        title: 'How do I report bugs or request features?',
        description: 'Visit our website at www.123todo.com for contact information and support options.',
      },
      {
        title: 'Why is there a 200 character limit for tasks?',
        description:
          'Brief tasks are more actionable. If you need more detail, break the task into smaller steps or use another tool for project documentation.',
      },
    ]}
  />

  <!-- Troubleshooting -->
  <section class="px-4 py-16 mx-auto max-w-4xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Troubleshooting</h2>
      <p class="text-xl text-gray-600 dark:text-gray-400">Common issues and solutions</p>
    </div>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h3>🔄 Tasks disappeared after browser update</h3>
      <p>Browser updates shouldn't clear localStorage, but it can happen. If this occurs:</p>
      <ol>
        <li>Check if you have an exported backup file</li>
        <li>Use Import Data to restore from backup</li>
        <li>Going forward, export data weekly</li>
      </ol>

      <h3>📡 App not working offline</h3>
      <p>
        Ensure you've visited the app while online at least once. Service workers need to cache the app files initially.
        If still having issues:
      </p>
      <ol>
        <li>Visit app.123todo.com while online</li>
        <li>Wait for the page to fully load</li>
        <li>Install as PWA for best offline experience</li>
        <li>Try going offline again</li>
      </ol>

      <h3>🔧 Can't install as PWA</h3>
      <p>PWA installation requirements vary by browser:</p>
      <ul>
        <li><strong>Chrome/Edge:</strong> Look for install icon in address bar</li>
        <li><strong>Safari iOS:</strong> Use Share → Add to Home Screen</li>
        <li><strong>Firefox:</strong> Limited PWA support, use browser bookmarks instead</li>
      </ul>

      <h3>📥 Import not working</h3>
      <p>If import fails:</p>
      <ol>
        <li>Ensure you're importing a file exported from 123 ToDo (not edited manually)</li>
        <li>Check that the file is valid JSON</li>
        <li>Try exporting current data, then importing the old file</li>
        <li>If corrupted, you may need to manually recreate tasks</li>
      </ol>

      <h3>🖱️ Drag and drop not working</h3>
      <p>
        Drag and drop works on desktop only. Mobile touch devices don't support drag and drop for task reordering. Use
        Edit to change priorities on mobile.
      </p>
    </div>
  </section>

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Using 123 ToDo',
        href: 'https://app.123todo.com',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="title"> Ready to get organized? </Fragment>

    <Fragment slot="subtitle">
      Now that you know how to use 123 ToDo, put it to work for you. No signup required.
    </Fragment>
  </CallToAction>
</Layout>
