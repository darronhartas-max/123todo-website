---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: '123 ToDo - FREE Simple, Powerful Task Management',
  description:
    'FREE priority-based task management with offline support, achievement tracking, and zero tracking. Your tasks, your control.',
  ignoreTitleTemplate: true,
  openGraph: {
    images: [
      {
        url: 'https://www.123todo.com/social-share.svg',
        width: 1200,
        height: 630,
      },
    ],
    type: 'website',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start Organizing',
        href: 'https://app.123todo.com',
        icon: 'tabler:rocket',
      },
      {
        text: 'Learn More',
        href: '#features',
      },
    ]}
    image={{
      src: '~/assets/images/productive-man.json',
      alt: 'Person organizing tasks with 123 ToDo - effective time management',
    }}
  >
    <Fragment slot="title">
      Simple, Powerful <br />
      <span class="text-accent dark:text-white highlight">Task Management</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="text-lg">
        Priority-based organization with **Shadow Backups** and **Mobile-First Persistence**. <br />
        <span class="font-semibold text-accent dark:text-white">Your tasks, your phone, your control.</span>
        <span class="text-purple-600 dark:text-purple-400 font-bold underline decoration-2 underline-offset-4"
          >TOTALLY FREE.</span
        > No accounts, no hassle.
      </span>
    </Fragment>
  </Hero>

  <!-- Features Section -->
  <Features
    id="features"
    tagline="Features"
    title="Everything you need to stay organized"
    subtitle="Built with simplicity and privacy in mind"
    classes={{
      container: '!py-6 md:!py-8',
    }}
    items={[
      {
        title: 'Priority-Based Organization',
        description:
          'Organize tasks with our 4-level priority system: Must Do, Should Do, Could Do, and On Hold. Focus on what matters most.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Mobile-First Persistence',
        description:
          'Install as a PWA on your mobile phone or desktop. We request persistent storage to ensure the OS never clears your tasks.',
        icon: 'tabler:device-mobile-bolt',
      },
      {
        title: 'Achievement Milestones',
        description:
          'Stay motivated with milestone celebrations at 5, 10, and 15 completed tasks per day. Track your productivity journey.',
        icon: 'tabler:trophy',
      },
      {
        title: 'Zero Tracking',
        description:
          'No analytics, no cookies, no tracking. Your data never leaves your device. Privacy-first by design.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Shadow Backups',
        description:
          'Enjoy peace of mind with automatic daily snapshots of your task list, stored internally as a secondary recovery point.',
        icon: 'tabler:history',
      },
      {
        title: 'Todoist Import',
        description:
          'Migrating is easy. Import your existing Todoist projects and tasks directly via CSV into our organized priority system.',
        icon: 'tabler:file-import',
      },
      {
        title: 'Premium Typography',
        description:
          'A clean, high-accessibility interface with standard font sizing (1.1rem) designed specifically for legibility on all screens.',
        icon: 'tabler:typography',
      },
    ]}
  />

  <!-- How It Works -->
  <Content
    isReversed
    tagline="How It Works"
    title="Get organized in 3 simple steps"
    items={[
      {
        title: '1. Add Your Tasks',
        description: 'Quickly add tasks with our simple interface. Each task can be up to 200 characters.',
      },
      {
        title: '2. Set Priorities',
        description: 'Assign priority levels to organize your workload. Drag and drop to reorder within each priority.',
      },
      {
        title: '3. Complete & Celebrate',
        description: 'Check off completed tasks and track your progress. Unlock achievement milestones as you go!',
      },
    ]}
    image={{
      src: '~/assets/images/screenshot-123todo-1.png',
      alt: '123 ToDo app screenshot showing task organization',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">No learning curve required</h3>
      <p class="text-lg">
        Start managing your tasks immediately. 123 ToDo is designed to be intuitive and straightforward, so you can
        focus on getting things done instead of learning software.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Privacy Promise -->
  <Content
    tagline="Privacy First"
    title="Your data stays yours"
    items={[
      {
        title: 'Local Storage Only',
        description: "All tasks are stored in your browser's localStorage. Nothing is sent to our servers.",
      },
      {
        title: 'No Registration Required',
        description:
          'No email, no password, no account. Start using immediately without giving up personal information.',
      },
      {
        title: 'Open Source Approach',
        description: "Built with transparency in mind. You can inspect the code and verify there's no tracking.",
      },
    ]}
    image={{
      src: '~/assets/images/happy-at-desk.jpg',
      alt: 'Happy person working at desk with secure task management',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Built for privacy, designed for simplicity
      </h3>
      <p class="text-lg">
        In an age of constant surveillance, 123 ToDo offers a refreshing alternative. We don't want your data, and we
        don't need it to provide you with excellent task management.
      </p>
    </Fragment>
  </Content>

  <!-- Latest Blog Posts -->
  <BlogLatestPosts
    title="Latest from our blog"
    information={`Productivity tips, feature updates, and insights on effective task management.`}
  />

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Started Now',
        href: 'https://app.123todo.com',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="title"> Ready to simplify your life? </Fragment>

    <Fragment slot="subtitle"> Start organizing your tasks today. No signup required, completely free. </Fragment>
  </CallToAction>
</Layout>
