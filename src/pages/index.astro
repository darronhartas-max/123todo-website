---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: '123 ToDo - Simple, Powerful Task Management',
  description: 'Priority-based task management with offline support, achievement tracking, and zero tracking. Your tasks, your control.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start Organizing',
        href: 'https://app.123todo.com',
        icon: 'tabler:rocket',
      },
      {
        text: 'Learn More',
        href: '#features'
      },
    ]}
    image={{
      src: '~/assets/images/hero-image.png',
      alt: '123 ToDo Task Management App'
    }}
  >
    <Fragment slot="title">
      Simple, Powerful <br/>
      <span class="text-accent dark:text-white highlight">Task Management</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="text-lg">
        Priority-based organization with offline support and achievement tracking. <br/>
        <span class="font-semibold">Your tasks, your control.</span> No tracking, no accounts, no hassle.
      </span>
    </Fragment>
  </Hero>

  <!-- Features Section -->
  <Features
    id="features"
    tagline="Features"
    title="Everything you need to stay organized"
    subtitle="Built with simplicity and privacy in mind"
    items={[
      {
        title: 'Priority-Based Organization',
        description: 'Organize tasks with our 4-level priority system: Must Do, Should Do, Could Do, and On Hold. Focus on what matters most.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Works Offline',
        description: 'Install as a PWA on your phone or desktop. All your tasks are stored locally and work without an internet connection.',
        icon: 'tabler:wifi-off',
      },
      {
        title: 'Achievement Milestones',
        description: 'Stay motivated with milestone celebrations at 5, 10, and 15 completed tasks per day. Track your productivity journey.',
        icon: 'tabler:trophy',
      },
      {
        title: 'Zero Tracking',
        description: 'No analytics, no cookies, no tracking. Your data never leaves your device. Privacy-first by design.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Export & Import',
        description: 'Your data belongs to you. Export to JSON anytime for backup or transfer between devices.',
        icon: 'tabler:file-export',
      },
      {
        title: 'Beautiful & Fast',
        description: 'Clean, modern interface that loads instantly. Built with React for a smooth, responsive experience.',
        icon: 'tabler:sparkles',
      },
    ]}
  />

  <!-- How It Works -->
  <Content
    isReversed
    tagline="How It Works"
    title="Get organized in 3 simple steps"
    items={[
      {
        title: '1. Add Your Tasks',
        description: 'Quickly add tasks with our simple interface. Each task can be up to 200 characters.',
      },
      {
        title: '2. Set Priorities',
        description: 'Assign priority levels to organize your workload. Drag and drop to reorder within each priority.',
      },
      {
        title: '3. Complete & Celebrate',
        description: 'Check off completed tasks and track your progress. Unlock achievement milestones as you go!',
      },
    ]}
    image={{
      src: '~/assets/images/default.png',
      alt: 'Task organization workflow'
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        No learning curve required
      </h3>
      <p class="text-lg">
        Start managing your tasks immediately. 123 ToDo is designed to be intuitive and straightforward,
        so you can focus on getting things done instead of learning software.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Privacy Promise -->
  <Content
    tagline="Privacy First"
    title="Your data stays yours"
    items={[
      {
        title: 'Local Storage Only',
        description: 'All tasks are stored in your browser\'s localStorage. Nothing is sent to our servers.',
      },
      {
        title: 'No Registration Required',
        description: 'No email, no password, no account. Start using immediately without giving up personal information.',
      },
      {
        title: 'Open Source Approach',
        description: 'Built with transparency in mind. You can inspect the code and verify there\'s no tracking.',
      },
    ]}
    image={{
      src: '~/assets/images/default.png',
      alt: 'Privacy-first design'
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Built for privacy, designed for simplicity
      </h3>
      <p class="text-lg">
        In an age of constant surveillance, 123 ToDo offers a refreshing alternative. We don't want your data,
        and we don't need it to provide you with excellent task management.
      </p>
    </Fragment>
  </Content>

  <!-- Latest Blog Posts -->
  <BlogLatestPosts
    title="Latest from our blog"
    information={`Productivity tips, feature updates, and insights on effective task management.`}
  />

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Started Now',
        href: 'https://app.123todo.com',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to simplify your life?
    </Fragment>

    <Fragment slot="subtitle">
      Start organizing your tasks today. No signup required, completely free.
    </Fragment>
  </CallToAction>
</Layout>
